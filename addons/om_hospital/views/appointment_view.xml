<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_hospital_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list decoration-success="gender == 'male'" sample="1">
                <field name="patient_id" />
                <field name="ref" optional="show" />
                <field name="doctor_id" widget="many2one_avatar_user"/>
                <field name="gender" optional="hide"/>
                <field name="appointment_time"/>
                <field name="booking_date" optional="show"/>
                <field name="activity_ids" widget="list_activity"/>
                <!-- <field name="testing" widget="CopyClipboardChar"/> -->
                <field name="status" decoration-info="status == 'draft'" decoration-success="status == 'done'"
                       decoration-warning="status == 'in_consultation'" decoration-danger="status == 'cancel'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <field name="status" widget="statusbar"
                               statusbar_visible="draft,in_consultation,done,cancel"
                               options="{'clickable': '1'}"
                               nollabel="1"/>
                    </header>
                    <oe_title>
                        <h2>
                            <field name="priority" widget="priority" class="mr-3 mb-3"/>
                        </h2>
                    </oe_title>
                    <group>
                        <group>
                            <field name="patient_id"/>
                 
                            <field name="ref"/>
                            <field name="doctor_id"/>
                            <field name="gender"/>
                            <field name="age"/>
                            <field name="street"/>
                            <field name="booking_date" default_focus="1"/>
                        </group>
                        <group>
                            <field name="appointment_time"/>
                            <button name="action_test" string="Test Action" type="object" class="oe_highlight"
                                    confirm="Are you sure you want to test this action?"
                                    help="This will test the action"/>
                            <button name="%(om_hospital.action_hospital_patient)d" string="Button Patient" type="action"
                                    class="oe_highlight"
                                    confirm="Are you sure you want to navigate to the patient form?"
                                    help="This will navigate to the patient form"/>

                        </group>

                    </group>
                    <notebook>
                        <page name="prescription" string="Prescription">
                            <field name="prescription" options="{'collaborative':true, 'rezizable':true}"/>
                        </page>
                        <page name="pharmacy" string="Pharmacy">
                        </page>s
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_hospital_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search>

            </search>
        </field>

    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first appointment !
            </p>
        </field>
    </record>
    <menuitem id="menu_patient_appointment" name="Appointment" parent="menu_appointment"
              action="action_hospital_appointment"
              sequence="4"/>
</odoo>