<odoo>
  <data>
    <!-- explicit list view definition -->

    <record model="ir.ui.view" id="testing_bang.list">
      <field name="name">testing_bang list</field>
      <field name="model">testing_bang.testing_bang</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
        </list>
      </field>
    </record>


    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="testing_bang">
      <field name="name">testing_bang window</field>
      <field name="res_model">testing_bang.testing_bang</field>
      <field name="view_mode">list,form</field>
    </record>


