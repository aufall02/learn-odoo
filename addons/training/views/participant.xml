<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="action_participant_male" model="ir.actions.act_window">
        <field name="name">Male Participants</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">training.participant</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('gender', '=', 'male')]</field>
        <field name="context">{'default_gender': 'male'}</field>

        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                No male participants found. Click here to add one.
            </p>
            <p>
                This section displays all male participants
                registered in the training program.
            </p>
        </field>
    </record>

    <record id="action_participant_female" model="ir.actions.act_window">
        <field name="name">Female Participants</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">training.participant</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('gender', '=', 'female')]</field>
        <field name="context">{'default_gender': 'female'}</field>

        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                No female participants found. Click here to add one.
            </p>
            <p>
                This section displays all female participants
                registered in the training program.
            </p>
        </field>
    </record>


    <record id="seq_training_participant" model="ir.sequence">
        <field name="name">Participant order</field>
        <field name="code">training.participant</field>
        <field name="prefix">A/%(y)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="implementation">standard</field>
    </record>

    <record id="view_training_participant_list" model="ir.ui.view">
        <field name="name">training.participant.list</field>
        <field name="model">training.participant</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="gender"/>
                <field name="street"/>
                <field name="mobile"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <record id="view_training_participant_form" model="ir.ui.view">
        <field name="name">training.participant.form</field>
        <field name="model">training.participant</field>
        <field name="arch" type="xml">
            <form>
                <field name="image_1920" widget="image" class="oe_avatar"/>
                <div class="oe_title">
                    <h3>
                        <label for="no_participant" string="No Participant"/>
                    </h3>
                    <h1>
                        <field name="no_participant"/>
                    </h1>
                </div>
                <group name="personal_information" string="Personal Information">
                    <group>
                        <field name="name"/>
                        <field name="gender"/>
                        <field name="email"/>
                    </group>
                    <group>
                        <field name="place_of_birth"/>
                        <field name="date_of_birth"/>
                        <field name="mobile"/>
                    </group>
                </group>
                <group name="address_information" string="Address Information">
                    <group colspan="4">
                        <field name="street"/>
                    </group>
                    <group>
                        <field name="province_id"/>
                        <field name="city_id" domain="[('province_id', '=', province_id)]"/>
                    </group>
                    <group>
                        <field name="district_id" domain="[('city_id', '=', city_id)]"/>
                        <field name="village_id" domain="[('district_id', '=', district_id)]"/>
                    </group>
                </group>
                <group>
                    <group>
                        <field name="education"/>
                        <field name="is_married"/>
                    </group>
                    <group>
                        <field name="occupation"/>
                    </group>
                </group>
                <group name="spouse_information" string="Spouse Information"
                       invisible="[('is_married', '=', False)]">
                    <group>
                        <field name="spouse_name"/>
                        <field name="spouse_phone"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <record id="participant_action" model="ir.actions.act_window">
        <field name="name">Participants</field>
        <field name="res_model">training.participant</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first participant!
            </p>
        </field>
    </record>

    <menuitem id="participant_menu_action"
              name="Participants"
              parent="training_menu_categ"
              action="participant_action"
              sequence="20"/>
    <menuitem
            id="menu_participant_male"
            name="Male Participants"
            parent="participant_menu_action"
            action="action_participant_male"
            sequence="25"/>

    <menuitem
            id="menu_participant_female"
            name="Female Participants"
            parent="participant_menu_action"
            action="action_participant_female"
            sequence="26"/>
</odoo>