<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_province_form" model="ir.ui.view">
        <field name="name">province.form</field>
        <field name="model">training.province</field>
        <field name="arch" type="xml">
            <form string="Province">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="alias"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_city_form" model="ir.ui.view">
        <field name="name">city.form</field>
        <field name="model">training.city</field>
        <field name="arch" type="xml">
            <form string="City">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_district_form" model="ir.ui.view">
        <field name="name">district.form</field>
        <field name="model">training.district</field>
        <field name="arch" type="xml">
            <form string="District">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_village_form" model="ir.ui.view">
        <field name="name">village.form</field>
        <field name="model">training.village</field>
        <field name="arch" type="xml">
            <form string="Village">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_province_list" model="ir.ui.view">
        <field name="name">province.list</field>
        <field name="model">training.province</field>
        <field name="arch" type="xml">
            <list string="Regions">
                <field name="name"/>
                <field name="code"/>
                <field name="alias"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_city_list" model="ir.ui.view">
        <field name="name">city.list</field>
        <field name="model">training.city</field>
        <field name="arch" type="xml">
            <list string="Regions">
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_district_list" model="ir.ui.view">
        <field name="name">district.list</field>
        <field name="model">training.district</field>
        <field name="arch" type="xml">
            <list string="Regions">
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_village_list" model="ir.ui.view">
        <field name="name">village.list</field>
        <field name="model">training.village</field>
        <field name="arch" type="xml">
            <list string="Regions">
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
            </list>
        </field>
    </record>



    <!-- Action to open the province views -->
    <record id="action_province" model="ir.actions.act_window">
        <field name="name">Provinces</field>
        <field name="res_model">training.province</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">training.city</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_district" model="ir.actions.act_window" >
        <field name="name">Districts</field>
        <field name="res_model">training.district</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id  ="action_village" model="ir.actions.act_window" >
        <field name="name">Villages</field>
        <field name="res_model">training.village</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu item for provinces -->
    <menuitem id="province_menu" name="Provinces" parent="region_menu_categ" action="action_province" sequence="30"/>
    <!-- Menu item for cities -->
    <menuitem id="city_menu" name="Cities" parent="region_menu_categ" action="action_city" sequence="40"/>
    <!-- Menu item for districts -->
    <menuitem id="district_menu" name="Districts" parent="region_menu_categ" action="action_district" sequence="50"/>
    <!-- Menu item for villages -->
    <menuitem id="village_menu" name="Villages" parent="region_menu_categ" action="action_village" sequence="60"/>
</odoo>