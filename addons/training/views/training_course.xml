<odoo>
    <record model="ir.actions.act_window" id="training_course_action">
        <field name="name">training window</field>
        <field name="res_model">training.course</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="training_course_view_list" model="ir.ui.view">
        <field name="name">training.course.list</field>
        <field name="model">training.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="training_course_view_form" model="ir.ui.view">
        <field name="name">training.course.form</field>
        <field name="model">training.course</field>
        <field name="arch" type="xml">
            <form string="Training Course">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="trainer_id"/>
                    </group>
                    <notebook>
                        <page name="session" string="Sessions Course">
                            <field name="session_ids" nolabel="1">
                                <list string="Sessions" editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="duration"/>
                                    <field name="seats"/>
                                </list>
                            </field>
                        </page>
                        <page name="description" string="Keterangan">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem name="Training Course"
              id="training_course_menu_action"
              parent="training_menu_categ"
              action="training_course_action"
              sequence="10"/>
</odoo>