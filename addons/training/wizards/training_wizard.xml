<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="wizard_training_view_form" model="ir.ui.view">
            <field name="name">training.wizard.view</field>
            <field name="model">training.wizard</field>
            <field name="arch" type="xml">
                <form string="">
                    <group>
                        <field name="session_id"/>
                        <field name="participant_ids"/>
                    </group>
                    <footer>
                        <button name="add_participant" string="Tambah Peserta" type="object" class="btn-primary"/>
                        <button string="cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="wizard_training_action" model="ir.actions.act_window">
            <field name="name">Training wizard</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">training.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_training_session" />
            <field name="view_mode">form</field>
            <field name="binding_view_types">form</field>
            
        </record>
    </data>
</odoo>